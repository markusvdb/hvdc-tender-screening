<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HVDC tender screening</title>
<style>
  :root {
    --bg: #ffffff; --bg-secondary: #f7f6f2;
    --text-primary: #1c1c1a; --text-secondary: #5f5e5a; --text-tertiary: #888780;
    --border: rgba(0,0,0,0.12);
    --info-bg: #e6f1fb; --info-text: #0c447c;
    --warn-bg: #faeeda; --warn-text: #854f0b;
    --success-bg: #e1f5ee; --success-text: #085041;
    --purple-bg: #eeedfe; --purple-text: #3c3489;
    --gray-bg: #f1efe8; --gray-text: #5f5e5a;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1c1c1a; --bg-secondary: #2c2c2a;
      --text-primary: #f1efe8; --text-secondary: #b4b2a9; --text-tertiary: #888780;
      --border: rgba(255,255,255,0.15);
      --info-bg: #0c447c; --info-text: #b5d4f4;
      --warn-bg: #633806; --warn-text: #fac775;
      --success-bg: #085041; --success-text: #9fe1cb;
      --purple-bg: #3c3489; --purple-text: #cecbf6;
      --gray-bg: #444441; --gray-text: #d3d1c7;
    }
  }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    color: var(--text-primary); background: var(--bg);
    margin: 0; padding: 2rem 1rem; line-height: 1.5;
  }
  .container { max-width: 880px; margin: 0 auto; }
  h1 { font-size: 22px; font-weight: 500; margin: 0 0 4px; }
  h2 { font-size: 18px; font-weight: 500; margin: 2.5rem 0 4px; }
  h2 .count { font-weight: 400; color: var(--text-secondary); font-size: 14px; margin-left: 8px; }
  .section-desc { font-size: 13px; color: var(--text-secondary); margin: 0 0 1rem; }
  .subtitle { font-size: 13px; color: var(--text-secondary); margin-bottom: 2rem; }
  .header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 8px; }
  .last-run { font-size: 12px; color: var(--text-tertiary); }
  .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 12px; margin-bottom: 1.5rem; }
  .stat { background: var(--bg-secondary); border-radius: 8px; padding: 1rem; }
  .stat-label { font-size: 13px; color: var(--text-secondary); }
  .stat-value { font-size: 24px; font-weight: 500; margin-top: 4px; }
  .stat-value.info { color: var(--info-text); }
  .stat-value.warn { color: var(--warn-text); }
  .filter-row { display: flex; gap: 8px; margin-bottom: 0.75rem; flex-wrap: wrap; align-items: center; }
  .filter-label { font-size: 12px; color: var(--text-secondary); margin-right: 4px; text-transform: uppercase; letter-spacing: 0.04em; }
  .fbtn {
    font-size: 12px; padding: 5px 11px; background: transparent;
    border: 0.5px solid var(--border); border-radius: 8px;
    cursor: pointer; color: var(--text-secondary); font-family: inherit;
  }
  .fbtn.active { background: var(--info-bg); color: var(--info-text); border-color: var(--info-text); }
  .fbtn.active-stage { background: var(--success-bg); color: var(--success-text); border-color: var(--success-text); }
  .fbtn:hover:not(.active):not(.active-stage) { background: var(--bg-secondary); }
  select {
    font-size: 12px; padding: 5px 8px; border: 0.5px solid var(--border);
    border-radius: 8px; background: transparent; color: var(--text-primary);
    font-family: inherit;
  }
  .tender {
    background: var(--bg); border: 0.5px solid var(--border);
    border-radius: 12px; padding: 1rem 1.25rem; margin-bottom: 10px;
  }
  .tender.bid { border-left: 3px solid var(--info-text); }
  .tender-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 6px; }
  .tender-title { font-size: 15px; font-weight: 500; margin: 0; }
  .tender-title a { color: var(--text-primary); text-decoration: none; }
  .tender-title a:hover { text-decoration: underline; }
  .tender-buyer { font-size: 13px; color: var(--text-secondary); margin: 4px 0 0; }
  .badges { display: flex; gap: 6px; flex-wrap: wrap; flex-shrink: 0; }
  .badge { font-size: 11px; padding: 3px 9px; border-radius: 8px; white-space: nowrap; font-weight: 500; }
  .b-bid { background: var(--info-bg); color: var(--info-text); }
  .b-intel { background: var(--gray-bg); color: var(--gray-text); }
  .b-corr { background: var(--warn-bg); color: var(--warn-text); }
  .b-award { background: var(--success-bg); color: var(--success-text); }
  .b-pipeline { background: var(--purple-bg); color: var(--purple-text); }
  .b-active { background: var(--success-bg); color: var(--success-text); }
  .b-fit-yes { background: var(--success-bg); color: var(--success-text); }
  .b-fit-partial { background: var(--warn-bg); color: var(--warn-text); }
  .tender-meta {
    display: flex; gap: 16px; font-size: 12px; color: var(--text-secondary);
    margin: 10px 0; flex-wrap: wrap;
  }
  .tender-meta strong { color: var(--text-primary); font-weight: 500; }
  .tender-summary { font-size: 13px; line-height: 1.6; color: var(--text-primary); margin: 10px 0; }
  .bid-fit-reason { font-size: 12px; color: var(--text-secondary); font-style: italic; margin: 4px 0 8px; }
  .tender-requirements { margin: 8px 0 0; padding-left: 1.2rem; font-size: 13px; color: var(--text-secondary); }
  .tender-requirements li { margin-bottom: 3px; }
  .tender-red-flag {
    font-size: 12px; color: var(--warn-text); margin-top: 8px;
    padding: 6px 10px; background: var(--warn-bg); border-radius: 6px;
  }
  .tender-kw { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
  .kw { font-size: 11px; padding: 2px 8px; background: var(--bg-secondary); border-radius: 6px; color: var(--text-secondary); }
  .kw-hvdc { background: var(--purple-bg); color: var(--purple-text); }
  .kw-service { background: var(--info-bg); color: var(--info-text); }
  .empty {
    text-align: center; padding: 2rem 1rem; color: var(--text-tertiary);
    border: 0.5px dashed var(--border); border-radius: 12px; font-size: 13px;
  }
  footer {
    margin-top: 3rem; padding-top: 1.5rem; border-top: 0.5px solid var(--border);
    font-size: 12px; color: var(--text-tertiary); text-align: center;
  }
  footer a { color: var(--text-tertiary); }
</style>
</head>
<body>
<div class="container">
  <div class="header">
    <div>
      <h1>HVDC tender screening</h1>
      <p class="subtitle">{{ this_week_label }} · {{ total_screened }} notices screened · {{ rejected_count }} rejected at HVDC gate</p>
    </div>
    <div class="last-run">Last run: {{ last_run_label }}</div>
  </div>

  <div class="stats">
    <div class="stat">
      <div class="stat-label">Bid candidates</div>
      <div class="stat-value info">{{ bid_count }}</div>
    </div>
    <div class="stat">
      <div class="stat-label">Market intel</div>
      <div class="stat-value">{{ intel_count }}</div>
    </div>
    <div class="stat">
      <div class="stat-label">Active tenders</div>
      <div class="stat-value">{{ active_count }}</div>
    </div>
    <div class="stat">
      <div class="stat-label">Pipeline</div>
      <div class="stat-value">{{ pipeline_count }}</div>
    </div>
    <div class="stat">
      <div class="stat-label">Corrigenda</div>
      <div class="stat-value warn">{{ corrigenda_count }}</div>
    </div>
  </div>

  <div class="filter-row">
    <span class="filter-label">Stage:</span>
    <button class="sbtn" data-stage="all">All ({{ total_visible }})</button>
    <button class="sbtn active-stage" data-stage="active">Active tenders ({{ active_count }})</button>
    <button class="sbtn" data-stage="pipeline">Pipeline ({{ pipeline_count }})</button>
    <button class="sbtn" data-stage="corrigendum">Corrigenda ({{ corrigenda_count }})</button>
    <button class="sbtn" data-stage="award">Awards ({{ award_count }})</button>
  </div>

  <div class="filter-row">
    <span class="filter-label">Scope:</span>
    <button class="fbtn active" data-filter="all">All</button>
    <button class="fbtn" data-filter="owners_engineer">Owner's engineer</button>
    <button class="fbtn" data-filter="feasibility">Feasibility / FEED</button>
    <button class="fbtn" data-filter="studies">Studies / EMT / grid</button>
    <button class="fbtn" data-filter="design_review">Design review</button>
    <button class="fbtn" data-filter="converter">Converter (intel)</button>
    <span style="flex: 1;"></span>
    <select id="source">
      <option value="all">All sources</option>
      <option value="FTS">FTS (UK)</option>
      <option value="TED">TED (EU)</option>
      <option value="WB">World Bank</option>
      <option value="Gmail">Portal alerts</option>
    </select>
  </div>

  <h2>1. Bid candidates<span class="count" id="bid-count-display">{{ bid_count }}</span></h2>
  <p class="section-desc">HVDC scope + RTEi-relevant service. Default view: active tenders.</p>

  <div id="bid-section">
    {% for t in bid_candidates %}
    <div class="tender bid"
         data-cats="{{ t.category_tags|join(',') }}"
         data-source="{{ t.source }}"
         data-stage="{{ t.stage }}">
      <div class="tender-head">
        <div style="flex: 1; min-width: 0;">
          <p class="tender-title"><a href="{{ t.url }}" target="_blank" rel="noopener">{{ t.title }}</a></p>
          <p class="tender-buyer">{{ t.buyer }} · {{ t.source }} · {{ t.notice_type }}{% if t.country %} · {{ t.country }}{% endif %}</p>
        </div>
        <div class="badges">
          <span class="badge b-{{ t.stage }}">{{ t.stage|capitalize }}</span>
          {% if t.summary and t.summary.rtei_bid_fit == 'yes' %}<span class="badge b-fit-yes">Fit: yes</span>
          {% elif t.summary and t.summary.rtei_bid_fit == 'partial' %}<span class="badge b-fit-partial">Fit: partial</span>
          {% endif %}
          <span class="badge b-bid">Bid candidate</span>
        </div>
      </div>
      <div class="tender-meta">
        {% if t.value_display %}<span><strong>Value:</strong> {{ t.value_display }}</span>{% endif %}
        {% if t.deadline_display %}<span><strong>Deadline:</strong> {{ t.deadline_display }}</span>{% endif %}
        {% if t.published_display %}<span><strong>Published:</strong> {{ t.published_display }}</span>{% endif %}
        <span><strong>Score:</strong> {{ t.score }}</span>
      </div>
      {% if t.summary and t.summary.scope_summary %}
      <p class="tender-summary">{{ t.summary.scope_summary }}</p>
      {% if t.summary.rtei_bid_fit_reason %}<p class="bid-fit-reason">Fit: {{ t.summary.rtei_bid_fit_reason }}</p>{% endif %}
      {% if t.summary.notable_requirements %}
      <ul class="tender-requirements">
        {% for req in t.summary.notable_requirements %}<li>{{ req }}</li>{% endfor %}
      </ul>
      {% endif %}
      {% if t.summary.red_flags %}
        {% for flag in t.summary.red_flags %}<div class="tender-red-flag">⚠ {{ flag }}</div>{% endfor %}
      {% endif %}
      {% endif %}
      <div class="tender-kw">
        {% for kw in t.gate_hits[:5] %}<span class="kw kw-hvdc">{{ kw }}</span>{% endfor %}
        {% for kw in t.service_hits[:3] %}<span class="kw kw-service">{{ kw }}</span>{% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
  <div id="bid-empty" class="empty" style="display:none;">No bid candidates matching current filters.</div>

  <h2>2. HVDC market intelligence<span class="count" id="intel-count-display">{{ intel_count }}</span></h2>
  <p class="section-desc">Other HVDC tenders — OEM/EPC/cable supply. Useful for tracking the market; not RTEi bid targets.</p>

  <div id="intel-section">
    {% for t in market_intel %}
    <div class="tender"
         data-cats="{{ t.category_tags|join(',') }}"
         data-source="{{ t.source }}"
         data-stage="{{ t.stage }}">
      <div class="tender-head">
        <div style="flex: 1; min-width: 0;">
          <p class="tender-title"><a href="{{ t.url }}" target="_blank" rel="noopener">{{ t.title }}</a></p>
          <p class="tender-buyer">{{ t.buyer }} · {{ t.source }} · {{ t.notice_type }}{% if t.country %} · {{ t.country }}{% endif %}</p>
        </div>
        <div class="badges">
          <span class="badge b-{{ t.stage }}">{{ t.stage|capitalize }}</span>
          <span class="badge b-intel">Market intel</span>
        </div>
      </div>
      <div class="tender-meta">
        {% if t.value_display %}<span><strong>Value:</strong> {{ t.value_display }}</span>{% endif %}
        {% if t.deadline_display %}<span><strong>Deadline:</strong> {{ t.deadline_display }}</span>{% endif %}
        {% if t.published_display %}<span><strong>Published:</strong> {{ t.published_display }}</span>{% endif %}
      </div>
      {% if t.summary and t.summary.scope_summary %}
      <p class="tender-summary">{{ t.summary.scope_summary }}</p>
      {% elif t.description %}
      <p class="tender-summary">{{ t.description_snippet }}</p>
      {% endif %}
      <div class="tender-kw">
        {% for kw in t.gate_hits[:4] %}<span class="kw kw-hvdc">{{ kw }}</span>{% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
  <div id="intel-empty" class="empty" style="display:none;">No market intel matching current filters.</div>

  <footer>
    <p>Generated {{ generated_at }} · <a href="https://github.com/{{ repo }}" target="_blank">source</a> · Data: FTS (OGL v3.0), TED (© EU), World Bank (CC BY 4.0), TSO portal alerts</p>
  </footer>
</div>

<script>
  function applyFilters() {
    const scope = document.querySelector(".fbtn.active").dataset.filter;
    const stage = document.querySelector(".sbtn.active-stage").dataset.stage;
    const src = document.getElementById("source").value;

    ["bid-section", "intel-section"].forEach(sectionId => {
      const tenders = document.querySelectorAll(`#${sectionId} .tender`);
      let visible = 0;
      tenders.forEach(t => {
        const cats = (t.dataset.cats || "").split(",");
        const tStage = t.dataset.stage || "";
        const tSrc = t.dataset.source || "";
        const matchScope = scope === "all" || cats.includes(scope);
        const matchStage = stage === "all" || tStage === stage;
        const matchSrc = src === "all" || tSrc === src;
        const show = matchScope && matchStage && matchSrc;
        t.style.display = show ? "" : "none";
        if (show) visible++;
      });
      const emptyEl = document.getElementById(sectionId.replace("-section", "-empty"));
      if (emptyEl) emptyEl.style.display = visible === 0 ? "" : "none";
      const countEl = document.getElementById(sectionId.replace("-section", "-count-display"));
      if (countEl) countEl.textContent = visible;
    });
  }

  document.querySelectorAll(".fbtn").forEach(b => b.addEventListener("click", () => {
    document.querySelectorAll(".fbtn").forEach(x => x.classList.remove("active"));
    b.classList.add("active");
    applyFilters();
  }));

  document.querySelectorAll(".sbtn").forEach(b => b.addEventListener("click", () => {
    document.querySelectorAll(".sbtn").forEach(x => x.classList.remove("active-stage"));
    b.classList.add("active-stage");
    applyFilters();
  }));

  document.getElementById("source").addEventListener("change", applyFilters);
  applyFilters();
</script>
</body>
</html>
