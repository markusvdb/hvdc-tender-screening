<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>HVDC bid candidates — week of {{ week_of }}</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; color: #1c1c1a; background: #ffffff; margin: 0; padding: 24px 16px; line-height: 1.5;">
<table role="presentation" style="max-width: 680px; margin: 0 auto; border-collapse: collapse; width: 100%;">
<tr><td>

<h1 style="font-size: 22px; font-weight: 500; margin: 0 0 6px;">HVDC bid candidates</h1>
<p style="font-size: 13px; color: #5f5e5a; margin: 0 0 24px;">Week of {{ week_of }} · {{ bid_count }} bid candidate{% if bid_count != 1 %}s{% endif %} · <a href="{{ dashboard_url }}" style="color: #185fa5;">Full dashboard with market intel</a></p>

{% if bid_candidates %}

{% for t in bid_candidates %}
<table role="presentation" style="width: 100%; border: 0.5px solid rgba(0,0,0,0.12); border-left: 3px solid #185fa5; border-radius: 12px; margin-bottom: 14px; border-collapse: separate;">
<tr><td style="padding: 14px 16px;">
  <div style="font-size: 11px; color: #5f5e5a; margin-bottom: 6px;">
    {{ t.source }} · {{ t.buyer }}{% if t.country %} · {{ t.country }}{% endif %}
    {% if t.summary and t.summary.rtei_bid_fit == 'yes' %} · <span style="color: #085041; font-weight: 500;">Fit: yes</span>
    {% elif t.summary and t.summary.rtei_bid_fit == 'partial' %} · <span style="color: #854f0b; font-weight: 500;">Fit: partial</span>
    {% endif %}
  </div>
  <a href="{{ t.url }}" style="font-size: 15px; font-weight: 500; color: #1c1c1a; text-decoration: none;">{{ t.title }}</a>
  <div style="font-size: 12px; color: #5f5e5a; margin: 8px 0;">
    {% if t.value_display %}<strong style="color: #1c1c1a;">Value:</strong> {{ t.value_display }} &nbsp;·&nbsp; {% endif %}
    {% if t.deadline_display %}<strong style="color: #1c1c1a;">Deadline:</strong> {{ t.deadline_display }} &nbsp;·&nbsp; {% endif %}
    <strong style="color: #1c1c1a;">Score:</strong> {{ t.score }}
  </div>
  {% if t.summary and t.summary.scope_summary %}
  <div style="font-size: 13px; color: #1c1c1a; margin: 10px 0;">{{ t.summary.scope_summary }}</div>
  {% if t.summary.rtei_bid_fit_reason %}
  <div style="font-size: 12px; color: #5f5e5a; font-style: italic; margin: 4px 0 8px;">Fit: {{ t.summary.rtei_bid_fit_reason }}</div>
  {% endif %}
  {% if t.summary.notable_requirements %}
  <ul style="font-size: 12px; color: #5f5e5a; margin: 8px 0; padding-left: 18px;">
    {% for req in t.summary.notable_requirements %}<li>{{ req }}</li>{% endfor %}
  </ul>
  {% endif %}
  {% if t.summary.red_flags %}
    {% for flag in t.summary.red_flags %}
    <div style="font-size: 12px; color: #854f0b; background: #faeeda; padding: 6px 10px; border-radius: 6px; margin-top: 6px;">⚠ {{ flag }}</div>
    {% endfor %}
  {% endif %}
  {% endif %}
</td></tr>
</table>
{% endfor %}

{% else %}

<div style="text-align: center; padding: 32px 16px; color: #888780; border: 0.5px dashed rgba(0,0,0,0.15); border-radius: 12px;">
  No bid candidates matched this week.<br>
  <span style="font-size: 12px;">Check the dashboard for HVDC market intelligence.</span>
</div>

{% endif %}

<p style="font-size: 11px; color: #888780; margin-top: 32px; text-align: center;">
  {{ total_screened }} notices screened · {{ intel_count }} market intel items available on the dashboard<br>
  Generated {{ generated_at }} UTC · <a href="{{ dashboard_url }}" style="color: #888780;">Full dashboard</a><br>
  Data: Find a Tender (UK, OGL v3.0), TED (EU)
</p>

</td></tr>
</table>
</body>
</html>
